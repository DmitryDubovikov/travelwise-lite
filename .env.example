# Free AI Studio key (https://aistudio.google.com/apikey) — no billing, no card.
# ADK reads GOOGLE_API_KEY; GOOGLE_GENAI_USE_VERTEXAI=FALSE keeps it on AI Studio.
GOOGLE_API_KEY=your-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Concrete pinned model ids — never a `-latest` alias, never a Pro model (paid-only).
MODEL_FLASH=gemini-3.6-flash
MODEL_FLASH_LITE=gemini-3.5-flash-lite

# Ports (nothing hardcoded in code)
SUPPLIER_PORT=8001
ADK_WEB_PORT=8000

# The ONLY way the planner knows the supplier (agent card, framework-served)
SUPPLIER_CARD_URL=http://localhost:8001/.well-known/agent-card.json
